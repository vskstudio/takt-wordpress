{
  "name": "vskstudio/takt-wordpress",
  "description": "WordPress plugin for Takt analytics: injects the privacy-first browser snippet + sends WooCommerce purchases as server-to-server events.",
  "type": "wordpress-plugin",
  "license": "MIT",
  "keywords": [
    "analytics",
    "takt",
    "wordpress",
    "woocommerce",
    "privacy",
    "tracking",
    "snippet"
  ],
  "homepage": "https://github.com/vskstudio/takt-wordpress",
  "authors": [
    {
      "name": "vskstudio"
    }
  ],
  "support": {
    "issues": "https://github.com/vskstudio/takt-wordpress/issues",
    "source": "https://github.com/vskstudio/takt-wordpress"
  },
  "require": {
    "php": ">=8.1",
    "vskstudio/takt-core-php": "^0.3",
    "nyholm/psr7": "^1.8"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^1.11",
    "friendsofphp/php-cs-fixer": "^3.59",
    "brain/monkey": "^2.6",
    "php-stubs/wordpress-stubs": "^6.5",
    "php-stubs/woocommerce-stubs": "^9.0",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "sniccowp/php-scoper-wordpress-excludes": "^6.9"
  },
  "autoload": {
    "psr-4": {
      "Vskstudio\\Takt\\WordPress\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Vskstudio\\Takt\\WordPress\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "scripts": {
    "test": "phpunit",
    "stan": "phpstan analyse --no-progress --memory-limit=512M",
    "cs": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix --dry-run --diff",
    "cs:fix": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix",
    "check": [
      "@cs",
      "@stan",
      "@test"
    ]
  },
  "minimum-stability": "stable"
}
